---
import Layout from "@/layouts/Layout.astro";
import site from "@/config/site";

const categoryLabels: Record<string, string> = {
  books: "Books",
  anime: "Anime",
  manga: "Manga",
  "webtoon-light-novel": "Webtoon / Light Novel",
};
---

<Layout
  title={site.labels.fictionTitle}
  description={site.labels.fictionDescription}
>
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-2xl p-8 duration-700 md:p-16"
  >
    <h2 class="mb-4 text-3xl font-bold">{site.labels.fictionTitle}</h2>
    <p class="mb-12 text-sm text-muted-foreground">
      {site.labels.fictionDescription}
    </p>

    <div class="space-y-10">
      {
        site.fiction.map((category) => (
          <section>
            <h3 class="mb-4 text-xs font-bold tracking-widest text-primary uppercase">
              {categoryLabels[category.name] ?? category.name}
            </h3>
            <div class="grid grid-cols-2 gap-5 sm:grid-cols-3 md:grid-cols-4">
              {category.items.map((item) => (
                <div class="group flex flex-col gap-3">
                  <div class="overflow-hidden rounded-xl border border-border/50 bg-muted/20">
                    <img
                      src={item.cover}
                      alt={item.title}
                      class="aspect-[2/3] w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                  <div class="px-1">
                    <span class="line-clamp-2 text-base leading-tight font-medium text-foreground/90">
                      {item.title}
                      {item.starred && <span class="ml-1">⭐</span>}
                    </span>
                    <span class="mt-0.5 inline-block text-xs font-bold tracking-wider text-muted-foreground uppercase">
                      {item.category}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</Layout>
